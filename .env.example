# Variables de entorno para Descargador de Expedientes
# =====================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a .env
# 2. Reemplaza los valores con tus credenciales
# 3. El archivo .env será ignorado por git (privado)
# 4. NUNCA commitees este archivo

# ═══════════════════════════════════════════════════════════════════════════
#  FLASK & SEGURIDAD
# ═══════════════════════════════════════════════════════════════════════════

# Ambiente: development, testing, production
FLASK_ENV=development

# Secret key para sesiones (cambiar en producción)
# Generar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# ═══════════════════════════════════════════════════════════════════════════
#  BASE DE DATOS
# ═══════════════════════════════════════════════════════════════════════════

# Desarrollo: SQLite (local)
# Producción: PostgreSQL (Render)
# Ejemplo: postgresql://usuario:password@localhost/descargador_db
DATABASE_URL=sqlite:///app.db

# ═══════════════════════════════════════════════════════════════════════════
#  STRIPE (pagos)
# ═══════════════════════════════════════════════════════════════════════════

# Obtén estas keys en: https://dashboard.stripe.com/account/apikeys
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ═══════════════════════════════════════════════════════════════════════════
#  REDIS (Celery - tareas asincrónicas)
# ═══════════════════════════════════════════════════════════════════════════

REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════
#  ANTHROPIC (Claude - procesamiento de documentos)
# ═══════════════════════════════════════════════════════════════════════════

# API KEY de Anthropic (para Claude)
# Obtén tu API key en: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-v4-...

# Modelo de Claude a usar (por defecto: claude-3-5-haiku)
CLAUDE_MODEL=claude-3-5-haiku
