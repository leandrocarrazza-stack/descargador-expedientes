# Variables de entorno para Descargador de Expedientes
# =====================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. El archivo .env será ignorado por git (privado)
# 4. NUNCA commitees .env — solo .env.example
#
# En producción (Render/Railway): configurar estas variables
# desde el panel de la plataforma, NO usar archivo .env

# ═══════════════════════════════════════════════════════════════════════════
#  FLASK & SEGURIDAD
# ═══════════════════════════════════════════════════════════════════════════

# Ambiente: development, testing, production
FLASK_ENV=development

# Secret key para sesiones y CSRF
# CAMBIAR EN PRODUCCIÓN — generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# ═══════════════════════════════════════════════════════════════════════════
#  BASE DE DATOS
# ═══════════════════════════════════════════════════════════════════════════

# Desarrollo: SQLite (local)
# Producción: PostgreSQL (Render provee la URL automáticamente)
# Ejemplo prod: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///app.db

# ═══════════════════════════════════════════════════════════════════════════
#  MERCADO PAGO (pagos)
# ═══════════════════════════════════════════════════════════════════════════

# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
MERCADO_PAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# URLs de retorno después del pago (ajustar dominio en producción)
MERCADO_PAGO_SUCCESS_URL=http://localhost:5000/pagos/pago-confirmado
MERCADO_PAGO_FAILURE_URL=http://localhost:5000/pagos/pago-fallido
MERCADO_PAGO_PENDING_URL=http://localhost:5000/pagos/pago-pendiente

# Webhook (solo en producción — Render/Railway da la URL pública)
# Configurar en el panel de MP: https://www.mercadopago.com.ar/developers/panel/app
# MERCADO_PAGO_NOTIFICATION_URL=https://tu-dominio.onrender.com/pagos/webhook

# ═══════════════════════════════════════════════════════════════════════════
#  REDIS (Celery - tareas asincrónicas)
# ═══════════════════════════════════════════════════════════════════════════

# Local: redis://localhost:6379/0
# Cloud: usar Upstash (free tier) o Redis Cloud
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════
#  MESA VIRTUAL (sesión de scraping)
# ═══════════════════════════════════════════════════════════════════════════

# Ruta donde guardar la sesión de Mesa Virtual (cookies).
# En Docker: apuntar a un volumen persistente.
# Si no se configura, usa ~/.mesa_virtual_sesion.pkl
# MESA_VIRTUAL_SESSION_PATH=/data/sesion.pkl

# ═══════════════════════════════════════════════════════════════════════════
#  CLOUD / DEPLOY
# ═══════════════════════════════════════════════════════════════════════════

# Horas que un PDF permanece en disco antes de ser borrado automáticamente.
# Reduce para servidores con poco disco. Default: 24
PDF_TTL_HOURS=24

# Cantidad de PDFs a unir por lote (menor = menos memoria, más lento).
# Para servidores con 512 MB RAM, usar 5-10. Default: 10
LOTE_UNIFICACION=10

# Activar compresión de PDF (requiere Ghostscript instalado).
# Consume CPU extra. Desactivado por defecto.
COMPRIMIR_PDF=false

# Calidad de compresión: screen (72dpi), ebook (150dpi), printer (300dpi)
COMPRESION_CALIDAD=ebook
